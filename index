<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Cosimo Mantovani</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">

  <style>
    :root {
      --bg: #ffffff;
      --text: #111;
      --muted: #6b6b6b;
      --line: rgba(17,17,17,.12);
      --card: #ece9e2;
      --max: 1680px;
      --pad: clamp(18px, 2vw, 34px);
      --radius: 16px;
    }

    * {
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      margin: 0;
      font-family: "Inter", "Helvetica Neue", Helvetica, Arial, sans-serif;
      color: var(--text);
      background: var(--bg);
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      text-rendering: optimizeLegibility;
    }

    img,
    video {
      display: block;
      max-width: 100%;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    button {
      font: inherit;
    }

    .wrap {
      width: min(calc(100% - 32px), var(--max));
      margin: 0 auto;
    }

    .site-header {
      position: sticky;
      top: 0;
      z-index: 50;
      backdrop-filter: blur(16px);
      background: color-mix(in srgb, var(--bg) 86%, white 14%);
      border-bottom: 1px solid transparent;
      transition: border-color .25s ease;
    }

    .site-header.scrolled {
      border-color: var(--line);
    }

    .topbar {
      display: grid;
      grid-template-columns: 1fr auto auto;
      align-items: center;
      gap: 20px;
      min-height: 84px;
      padding: 0 var(--pad);
    }

    .brand {
      font-size: clamp(22px, 2vw, 32px);
      font-weight: 500;
      letter-spacing: -0.045em;
      line-height: 1;
    }

    .desktop-nav {
      display: flex;
      align-items: center;
      gap: 26px;
    }

    .nav-link {
      position: relative;
      font-size: 13px;
      font-weight: 500;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: .09em;
      padding: 10px 0;
      transition: color .2s ease;
    }

    .nav-link:hover,
    .nav-link:focus-visible,
    .nav-link.active {
      color: var(--text);
    }

    .nav-toggle {
      display: none;
      border: 0;
      background: transparent;
      padding: 6px 0;
      font-size: 13px;
      text-transform: uppercase;
      letter-spacing: .12em;
      color: var(--text);
      cursor: pointer;
    }

    .mobile-panel {
      display: none;
      border-top: 1px solid var(--line);
      padding: 12px var(--pad) 22px;
    }

    .mobile-panel.open {
      display: block;
    }

    .mobile-panel a {
      display: block;
      padding: 14px 0;
      border-bottom: 1px solid var(--line);
      text-transform: uppercase;
      font-size: 14px;
      letter-spacing: .08em;
    }

    .hero {
      padding: 52px var(--pad) 26px;
    }

    .hero-grid {
      display: grid;
      grid-template-columns: 1.2fr .8fr;
      gap: 42px;
      align-items: end;
    }

    .intro {
      font-size: clamp(32px, 4.4vw, 72px);
      font-weight: 500;
      line-height: .95;
      letter-spacing: -.06em;
      margin: 0;
      max-width: 14ch;
    }

    .intro-meta {
      max-width: 52ch;
      color: var(--muted);
      font-size: 15px;
      font-weight: 400;
      line-height: 1.7;
      justify-self: end;
    }

    .section-label {
      margin: 0 0 10px;
      color: var(--muted);
      font-size: 13px;
      text-transform: uppercase;
      letter-spacing: .1em;
    }

    .featured-start {
      padding-top: 12px;
    }

    .featured-project {
      padding: 52px var(--pad) 66px;
      border-top: 1px solid var(--line);
    }

    .project-head {
      display: grid;
      grid-template-columns: .65fr 1.35fr;
      gap: 30px;
      align-items: start;
      margin-bottom: 28px;
    }

    .project-kicker {
      color: var(--muted);
      font-size: 12px;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: .12em;
      margin-bottom: 12px;
    }

    .project-title {
      margin: 0 0 12px;
      font-size: clamp(32px, 4.2vw, 68px);
      font-weight: 500;
      line-height: .95;
      letter-spacing: -.06em;
    }

    .project-text {
      margin: 0;
      max-width: 60ch;
      color: var(--muted);
      font-size: 15px;
      font-weight: 400;
      line-height: 1.8;
    }

    .project-link {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      margin-top: 22px;
      padding-bottom: 4px;
      border-bottom: 1px solid var(--text);
      font-size: 12px;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: .12em;
    }

    .project-media {
      display: grid;
      grid-template-columns: repeat(12, 1fr);
      gap: 14px;
    }

    .project-media figure,
    .archive-preview-grid figure {
      margin: 0;
      overflow: hidden;
      border-radius: var(--radius);
      background: #ddd;
    }

    .project-media img,
    .project-media video,
    .archive-preview-grid img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform .7s ease;
    }

    figure:hover img,
    figure:hover video {
      transform: scale(1.02);
    }

    .span-12 {
      grid-column: span 12;
      min-height: 720px;
    }

    .span-8 {
      grid-column: span 8;
      min-height: 560px;
    }

    .span-6 {
      grid-column: span 6;
      min-height: 520px;
    }

    .span-4 {
      grid-column: span 4;
      min-height: 420px;
    }

    .archive {
      padding: 64px var(--pad) 80px;
      border-top: 1px solid var(--line);
    }

    .archive-head {
      display: flex;
      align-items: end;
      justify-content: space-between;
      gap: 24px;
      margin-bottom: 28px;
    }

    .archive-title {
      margin: 0;
      font-size: clamp(30px, 3.2vw, 54px);
      font-weight: 500;
      line-height: .95;
      letter-spacing: -.05em;
    }

    .archive-intro {
      max-width: 52ch;
      color: var(--muted);
      font-size: 16px;
      line-height: 1.6;
    }

    .archive-link {
      margin-top: 40px;
      display: flex;
      justify-content: center;
    }

    .archive-button {
      display: inline-block;
      padding: 14px 26px;
      border: 1px solid #111;
      border-radius: 30px;
      font-size: 13px;
      letter-spacing: .08em;
      text-transform: uppercase;
      transition: .25s;
    }

    .archive-button:hover {
      background: #111;
      color: #fff;
    }

    .archive-preview-grid {
      margin-top: 32px;
      display: grid;
      grid-template-columns: repeat(12, 1fr);
      gap: 14px;
    }

    .contact-strip {
      padding: 80px var(--pad);
      border-top: 1px solid var(--line);
    }

    .contact-strip-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 30px;
      align-items: end;
    }

    .contact-strip-title {
      margin: 0;
      font-size: clamp(30px, 3.6vw, 58px);
      font-weight: 500;
      line-height: .95;
      letter-spacing: -.05em;
    }

    .contact-strip-links {
      display: grid;
      gap: 14px;
      justify-self: end;
      width: min(100%, 460px);
    }

    .contact-strip-link {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 20px;
      padding-bottom: 10px;
      border-bottom: 1px solid var(--line);
      color: var(--muted);
      transition: color .25s ease;
      font-size: 15px;
    }

    .contact-strip-link:hover {
      color: var(--text);
    }

    .contact-strip-label {
      font-size: 12px;
      font-weight: 500;
      letter-spacing: .12em;
      text-transform: uppercase;
    }

    .site-footer {
      padding: 28px var(--pad) 44px;
      border-top: 1px solid var(--line);
      display: flex;
      justify-content: space-between;
      gap: 20px;
      color: var(--muted);
      font-size: 14px;
    }

    @media (max-width: 1100px) {
      .hero-grid,
      .project-head,
      .archive-head,
      .contact-strip-grid {
        grid-template-columns: 1fr;
      }

      .intro-meta {
        justify-self: start;
      }

      .archive-head {
        align-items: flex-start;
      }

      .contact-strip-links {
        justify-self: start;
      }
    }

    @media (max-width: 820px) {
      .desktop-nav {
        display: none;
      }

      .nav-toggle {
        display: inline-block;
      }

      .hero {
        padding-top: 28px;
      }

      .project-media,
      .archive-preview-grid {
        grid-template-columns: 1fr;
      }

      .span-12,
      .span-8,
      .span-6,
      .span-4 {
        grid-column: span 1;
        grid-row: span 1;
        min-height: 320px;
      }

      .site-footer {
        flex-direction: column;
      }
    }
  </style>
</head>

<body>
  <header class="site-header" id="siteHeader">
    <div class="wrap topbar">
      <a href="index.html" class="brand">Cosimo Mantovani Designer</a>

      <nav class="desktop-nav" aria-label="Navigazione principale">
        <a class="nav-link active" href="index.html">Work</a>
        <a class="nav-link" href="Archivo.html">Archive</a>
        <a class="nav-link" href="about.html">About</a>
        <a class="nav-link" href="contact.html">Contact</a>
      </nav>

      <button class="nav-toggle" id="navToggle" aria-expanded="false" aria-controls="mobilePanel">Menu</button>
    </div>

    <div class="mobile-panel wrap" id="mobilePanel">
      <a href="index.html">Work</a>
      <a href="archive.html">Archive</a>
      <a href="about.html">About</a>
      <a href="contact.html">Contact</a>
    </div>
  </header>

  <main id="top">
    <section class="hero wrap" id="about-home">
      <div class="hero-grid">
        <h1 class="intro">Product designer focused on industrial products.</h1>

        <div class="intro-meta">
          Sono un product designer che si occupa di progettazione di prodotto e comunicazione visiva. Il mio lavoro parte
          dall’ideazione del concept e arriva allo sviluppo del progetto attraverso modellazione 3D, prototipazione e definizione
          dell’identità formale del prodotto. Affianco alla progettazione industriale attività di grafica, rendering e costruzione
          di materiali di comunicazione, con l’obiettivo di sviluppare progetti coerenti sia dal punto di vista tecnico che visivo.
        </div>
      </div>
    </section>

    <section id="featured" class="featured-start"></section>

    <section class="archive wrap" id="archive">
      <div class="archive-head">
        <div>
          <p class="section-label">Selected works</p>
          <h2 class="archive-title">Product archive</h2>
        </div>

        <div class="archive-intro">
          Una raccolta separata di progetti, concept e lavori precedenti.
        </div>
      </div>

      <div class="archive-link">
        <a href="Archivo.html" class="archive-button">Vedi tutti i progetti</a>
      </div>

      <div class="archive-preview-grid" id="archivePreviewGrid"></div>
    </section>

    <section class="contact-strip wrap" id="contact-strip">
      <div class="contact-strip-grid">
        <h2 class="contact-strip-title">Contact</h2>

        <div class="contact-strip-links">
          <a class="contact-strip-link" href="https://www.linkedin.com/in/cosimomantovani/" target="_blank" rel="noreferrer">
            <span class="contact-strip-label">LinkedIn</span>
            <span>cosimomantovani</span>
          </a>

          <a class="contact-strip-link" href="https://www.instagram.com/cosimo_mantovani_designer/" target="_blank" rel="noreferrer">
            <span class="contact-strip-label">Instagram</span>
            <span>@cosimo_mantovani_designer</span>
          </a>

          <a class="contact-strip-link" href="mailto:cosimomantovanidesigner@gmail.com">
            <span class="contact-strip-label">Email</span>
            <span>cosimomantovanidesigner@gmail.com</span>
          </a>
        </div>
      </div>
    </section>
  </main>

  <footer class="site-footer wrap">
    <div>Cosimo Mantovani Designer</div>
    <div>
      <a href="mailto:cosimomantovanidesigner@gmail.com">cosimomantovanidesigner@gmail.com</a> ·
      <a href="https://www.linkedin.com/in/cosimomantovani/" target="_blank" rel="noreferrer">LinkedIn</a>
    </div>
  </footer>

  <script>
    const siteData = {
      featured: [
        {
          category: 'Industrial design',
          title: 'Novacom',
          text: 'Novacom è un sistema intercom industriale progettato per Althink come ridefinizione del modo in cui si comunica nei contesti critici. Il progetto nasce dall’analisi dei limiti dei dispositivi esistenti e propone una soluzione che unisce identità formale, comunicazione visiva e integrazione con sistemi industriali.',
          link: 'Novacom.html',
          media: [
            { type: 'image', src: 'images/Novacom1.jpg', span: 'span-6', alt: 'Main image Novacom' },
            { type: 'image', src: 'images/Novacom2.jpg', span: 'span-6', alt: 'Detail image 1' },
            { type: 'image', src: 'images/NovacomBlack2.jpg', span: 'span-6', alt: 'Detail image 2' },
            { type: 'image', src: 'images/Genova.jpg', span: 'span-6', alt: 'Detail image 3' }
          ]
        },
        {
          category: 'Product Design',
          title: 'LookOut Firecom',
          text: 'LookOut Firecom è un dispositivo di monitoraggio progettato per ambienti non industriali, dove la sicurezza deve essere chiara e non invasiva. La forma, ispirata a una torretta di avvistamento, lo rende immediatamente individuabile nello spazio, trasformandolo in un presidio visivo riconoscibile.',
          link: 'Lookout.html',
          media: [
            { type: 'image', src: 'images/Firecomevo1.jpg', span: 'span-8', alt: 'Dashboard image 1' },
            { type: 'image', src: 'images/Firecom3.jpg', span: 'span-4', alt: 'Dashboard image 2' },
            { type: 'image', src: 'images/Firecom2.jpg', span: 'span-4', alt: 'Dashboard image 3' },
            { type: 'image', src: 'images/Firecom.png', span: 'span-8', alt: 'Dashboard image 4' }
          ]
        },
        {
          category: 'Product Design',
          title: 'Delorean Futuro',
          text: 'Delorean Futuro è un concept di sportscar alimentata a idrogeno che esplora una possibile evoluzione della celebre Delorean del 1981. Il progetto immagina una nuova macchina del tempo capace di unire prestazioni sportive e propulsione a idrogeno, reinterpretando le forme iconiche del modello originale.',
          link: 'Delorean.html',
          media: [
            { type: 'image', src: 'images/Delorean1.jpg', span: 'span-8', alt: 'Dashboard image 1' },
            { type: 'image', src: 'images/Delorean11.1.jpg', span: 'span-4', alt: 'Dashboard image 2' },
            { type: 'image', src: 'images/Delorean13.jpg', span: 'span-6', alt: 'Dashboard image 3' },
            { type: 'image', src: 'images/Delorean5.Jpg', span: 'span-6', alt: 'Dashboard image 4' }
          ]
        },
        {
          category: 'Graphic Design',
          title: 'Trumpolis',
          text: 'Trumpolis nasce come progetto sviluppato per un concorso promosso da ADI, con l’obiettivo di tradurre l’immaginario di Metropolis in un linguaggio visivo contemporaneo applicato al mondo dello skateboard.',
          link: 'Trumpolis.html',
          media: [
            { type: 'image', src: 'images/Trumpolis.jpg', span: 'span-4', alt: 'Dashboard image 1' },
            { type: 'image', src: 'images/Trumpolis2.jpg', span: 'span-4', alt: 'Dashboard image 2' },
            { type: 'image', src: 'images/Trumpolis3.jpg', span: 'span-4', alt: 'Dashboard image 3' }
          ]
        },
        {
          category: 'Restyling',
          title: 'PTSS Suspension Seat',
          text: 'PTSS nasce come intervento di restyling mirato, sviluppato per ridefinire la percezione del prodotto e rafforzarne la coerenza con l’identità del brand.',
          link: 'PTSS.html',
          media: [
            { type: 'image', src: 'images/PTSS.jpg', span: 'span-4', alt: 'Dashboard image 1' },
            { type: 'image', src: 'images/PTSS2.jpg', span: 'span-4', alt: 'Dashboard image 2' },
            { type: 'image', src: 'images/PTSS4.Jpg', span: 'span-4', alt: 'Dashboard image 3' }
          ]
        }
      ]
    };

    const archivePreview = [
      { type: 'image', src: 'images/Museo5.jpg', span: 'span-4', alt: 'Dashboard image 1' },
      { type: 'image', src: 'images/Sauoro4.jpg', span: 'span-4', alt: 'Dashboard image 2' },
      { type: 'image', src: 'images/Estrusore3.Jpg', span: 'span-4', alt: 'Dashboard image 3' }
    ];

    const featuredRoot = document.getElementById('featured');
    const archivePreviewRoot = document.getElementById('archivePreviewGrid');

    function renderMediaItem(media) {
      if (media.type === 'video') {
        return `
          <figure class="${media.span}">
            <video autoplay muted loop playsinline>
              <source src="${media.src}" type="${media.mime || 'video/mp4'}">
              Il browser non supporta il video.
            </video>
          </figure>
        `;
      }

      return `
        <figure class="${media.span}">
          <img src="${media.src}" alt="${media.alt || ''}">
        </figure>
      `;
    }

    function renderFeatured() {
      featuredRoot.innerHTML = siteData.featured.map((project) => `
        <article class="featured-project wrap">
          <div class="project-head">
            <div>
              <div class="project-kicker">${project.category}</div>
            </div>
            <div>
              <h2 class="project-title">${project.title}</h2>
              <p class="project-text">${project.text}</p>
              <a class="project-link" href="${project.link}">Read more</a>
            </div>
          </div>
          <div class="project-media">
            ${project.media.map(renderMediaItem).join('')}
          </div>
        </article>
      `).join('');
    }

    function renderArchivePreview() {
      archivePreviewRoot.innerHTML = archivePreview.map(media => `
        <figure class="${media.span}">
          <img src="${media.src}" alt="${media.alt || ''}">
        </figure>
      `).join('');
    }

    renderFeatured();
    renderArchivePreview();

    const header = document.getElementById('siteHeader');
    window.addEventListener('scroll', () => {
      header.classList.toggle('scrolled', window.scrollY > 10);
    });

    const navToggle = document.getElementById('navToggle');
    const mobilePanel = document.getElementById('mobilePanel');

    navToggle.addEventListener('click', () => {
      const isOpen = mobilePanel.classList.toggle('open');
      navToggle.setAttribute('aria-expanded', String(isOpen));
    });
  </script>
</body>
</html>
